# API base URL - webapp backend (same as desktop)
# Simulator/Emulator: http://localhost:3001
# Physical device: Use your Mac's LAN IP! Run: ipconfig getifaddr en0
#   Example: http://192.168.1.100:3001
# Prod: https://your-domain.com
EXPO_PUBLIC_API_URL=http://localhost:3001

# Socket.IO server URL for real-time notifications
# Simulator: http://localhost:3004
# Physical device: Same LAN IP as API, port 3004 (e.g. http://192.168.1.100:3004)
EXPO_PUBLIC_SOCKET_URL=http://localhost:3004
